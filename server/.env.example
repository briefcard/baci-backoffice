PORT=8080
APP_URL=http://localhost:5173

# --- Shopify ---
SHOPIFY_STORE=769684-2.myshopify.com
SHOPIFY_API_VERSION=2025-01
# OAuth app credentials (Client ID / Secret). Install once at /auth/shopify/install to mint a token.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,read_inventory,read_locations,read_draft_orders,write_draft_orders
# Optional: a static Admin API token (custom app). If set, it's used instead of OAuth.
SHOPIFY_ADMIN_TOKEN=
# Webhook HMAC secret — defaults to SHOPIFY_API_SECRET when blank.
SHOPIFY_WEBHOOK_SECRET=

# --- Confirmed business settings (defaults shown) ---
SELLABLE_LOCATION_IDS=gid://shopify/Location/104277705016
LOW_STOCK_THRESHOLD=10
DEFAULT_WHOLESALE_PCT=50

# Per-event access code for the PUBLIC (QR) customer order form. Customers open
# https://<app>/?form=<code> on their own phones. Unset = public form disabled
# (kiosk form mode on rep tablets always works). Rotate per tradeshow.
ORDER_FORM_CODE=

# --- M1 fast start: skip auth so you only need the Shopify token to see the lookup UI ---
AUTH_DISABLED=true

# --- Interim email+password auth (no Resend needed). JSON list of reps. ---
# REP_LOGINS=[{"email":"jane@bacimilanousa.com","name":"Jane","password":"changeme1"},{"email":"rob@bacimilanousa.com","name":"Rob","password":"changeme2"}]

# --- M2 auth + infra (set when ready) ---
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=
RESEND_API_KEY=
MAGIC_LINK_FROM=Baci Reps <reps@bacimilanousa.com>
